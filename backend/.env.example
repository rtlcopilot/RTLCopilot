# RTLCopilot Backend — copy this to .env and fill in your values

# Supabase (required for normal mode)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
ALLOWED_ORIGINS=http://localhost:5173

# Offline mode — set to true to bypass Supabase auth entirely
# Contributors: set this to skip Google OAuth and Supabase setup
# OFFLINE_MODE=true
