# RTLCopilot Frontend — copy this to .env and fill in your values

# Supabase (required for normal mode)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_URL=http://localhost:8080

# Offline mode — set to true to bypass Supabase auth entirely
# Contributors: set this to skip Google OAuth and Supabase setup
# VITE_OFFLINE_MODE=true
